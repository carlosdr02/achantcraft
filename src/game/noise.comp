#version 450

layout(local_size_x = 32, local_size_y = 32) in;

layout(set = 0, binding = 0) writeonly buffer VertexBuffer {
    vec4 vertices[1024];
} vertexBuffer;

void main() {
    vertexBuffer.vertices[gl_LocalInvocationIndex] = vec4(gl_LocalInvocationID.x, 0.0, gl_LocalInvocationID.y, 1.0);
}
